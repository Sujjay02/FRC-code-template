{
  "name": "frc-jumpstart",
  "displayName": "FRC Jumpstart",
  "description": "Template-driven generator for WPILib 2026 Java robot code. Swerve, tank, mechanisms, LEDs, vision, PathPlanner — dropped straight into src/main/java/frc/robot/.",
  "version": "0.1.0",
  "publisher": "frc-jumpstart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sujjay02/FRC-code-template"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "frc",
    "wpilib",
    "swerve",
    "pathplanner",
    "first robotics"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "frcJumpstart",
          "title": "FRC Jumpstart",
          "icon": "media/frc-jumpstart.svg"
        }
      ]
    },
    "views": {
      "frcJumpstart": [
        {
          "type": "webview",
          "id": "frcJumpstart.panel",
          "name": "FRC Jumpstart",
          "icon": "media/frc-jumpstart.svg"
        }
      ]
    },
    "commands": [
      { "command": "frcJumpstart.open",             "title": "FRC Jumpstart: Open",                    "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newSwerve",        "title": "FRC Jumpstart: New Swerve Drive",        "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newTank",          "title": "FRC Jumpstart: New Tank Drive",          "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newMecanum",       "title": "FRC Jumpstart: New Mecanum Drive",       "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newShooter",       "title": "FRC Jumpstart: New Flywheel Shooter",    "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newShooterHopper", "title": "FRC Jumpstart: New Shooter + Hopper",    "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newTurret",        "title": "FRC Jumpstart: New Turret",              "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newPuncher",       "title": "FRC Jumpstart: New Puncher / Kicker",    "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newCatapult",      "title": "FRC Jumpstart: New Catapult",            "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newIntake",        "title": "FRC Jumpstart: New Intake (Roller)",     "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newDeployIntake",  "title": "FRC Jumpstart: New Intake with Deploy Arm","category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newConveyor",      "title": "FRC Jumpstart: New Conveyor / Belt",     "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newSerializer",    "title": "FRC Jumpstart: New Serializer",          "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newElevator",      "title": "FRC Jumpstart: New Elevator",            "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newArm",           "title": "FRC Jumpstart: New Pivot Arm",           "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newDoubleArm",     "title": "FRC Jumpstart: New Double-Jointed Arm",  "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newWrist",         "title": "FRC Jumpstart: New Wrist",               "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newTelescope",     "title": "FRC Jumpstart: New Telescope / Extension","category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newMechanism",     "title": "FRC Jumpstart: New Generic Mechanism",   "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newClimb",         "title": "FRC Jumpstart: New Climb",               "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newBuddyClimb",    "title": "FRC Jumpstart: New Buddy Climb",         "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newClaw",          "title": "FRC Jumpstart: New Claw / Gripper",      "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newPneumatics",    "title": "FRC Jumpstart: New Pneumatics",          "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newVision",        "title": "FRC Jumpstart: New Vision",              "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newLeds",          "title": "FRC Jumpstart: New Addressable LEDs",    "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newPathPlanner",   "title": "FRC Jumpstart: New PathPlanner Autos",   "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.newChoreo",        "title": "FRC Jumpstart: New Choreo Autos",        "category": "FRC Jumpstart" },
      { "command": "frcJumpstart.combine",          "title": "FRC Jumpstart: Combine Templates",       "category": "FRC Jumpstart" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.24.0"
  }
}
