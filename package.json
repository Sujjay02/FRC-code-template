{
  "name": "frc-forge",
  "displayName": "FRC Forge",
  "description": "Template-driven generator for WPILib 2026 Java robot code. Swerve, tank, mechanisms, LEDs, vision, PathPlanner — dropped straight into src/main/java/frc/robot/.",
  "version": "0.1.0",
  "publisher": "frc-forge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sujjay02/FRC-code-template"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "frc",
    "wpilib",
    "swerve",
    "pathplanner",
    "first robotics"
  ],
  "extensionDependencies": [
    "vscode.microsoft-authentication"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "frcForge",
          "title": "FRC Forge",
          "icon": "media/frc-forge.svg"
        }
      ]
    },
    "views": {
      "frcForge": [
        {
          "type": "webview",
          "id": "frcForge.panel",
          "name": "FRC Forge",
          "icon": "media/frc-forge.svg"
        }
      ]
    },
    "commands": [
      { "command": "frcForge.open",             "title": "FRC Forge: Open",                 "category": "FRC Forge" },
      { "command": "frcForge.newSwerve",        "title": "FRC Forge: New Swerve Drive",     "category": "FRC Forge" },
      { "command": "frcForge.newTank",          "title": "FRC Forge: New Tank Drive",       "category": "FRC Forge" },
      { "command": "frcForge.newShooter",       "title": "FRC Forge: New Shooter",          "category": "FRC Forge" },
      { "command": "frcForge.newShooterHopper", "title": "FRC Forge: New Shooter + Hopper","category": "FRC Forge" },
      { "command": "frcForge.newIntake",        "title": "FRC Forge: New Intake",           "category": "FRC Forge" },
      { "command": "frcForge.newElevator",      "title": "FRC Forge: New Elevator",         "category": "FRC Forge" },
      { "command": "frcForge.newClimb",         "title": "FRC Forge: New Climb",            "category": "FRC Forge" },
      { "command": "frcForge.newMechanism",     "title": "FRC Forge: New Generic Mechanism","category": "FRC Forge" },
      { "command": "frcForge.newLeds",          "title": "FRC Forge: New Addressable LEDs", "category": "FRC Forge" },
      { "command": "frcForge.newVision",        "title": "FRC Forge: New Vision",           "category": "FRC Forge" },
      { "command": "frcForge.newPathPlanner",   "title": "FRC Forge: New PathPlanner Autos","category": "FRC Forge" },
      { "command": "frcForge.combine",          "title": "FRC Forge: Combine Templates",    "category": "FRC Forge" },
      { "command": "frcForge.signInAzure",      "title": "FRC Forge: Sign in to Azure",     "category": "FRC Forge" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.24.0"
  }
}
